Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^src/ - [F,L,NC]
    RewriteRule ^storage/ - [F,L,NC]
    RewriteRule ^tools/ - [F,L,NC]

    RewriteRule ^assets/(.*)$ public/assets/$1 [L,NC]
    RewriteRule ^uploads/(.*)$ public/uploads/$1 [L,NC]

    RewriteRule ^(index|login|logout|register|add|photo|search)\.php$ public/$1.php [L,NC]
    RewriteRule ^$ public/index.php [L]
</IfModule>

<FilesMatch "\.(ini|log|sql|sqlite)$">
    Require all denied
</FilesMatch>
